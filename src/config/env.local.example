# 信息智能分析系统 - 本地环境覆盖配置
#
# 作用：覆盖 config/app.json 中的配置（环境变量优先），用于存放敏感信息（LLM Key 等）。
# 持久：此文件不被 Jenkins 部署覆盖（rsync 排除）、不入 Git（.gitignore 忽略）。
# 用法：cp config/env.local.example config/env.local，填入真实值，然后重启服务。
# 建议：chmod 600 config/env.local（仅属主可读）
#
# 重要：国内服务器通常无法直连 api.openai.com，请改用可达的 OpenAI 兼容 endpoint，
#       例如 DeepSeek / 通义千问(DashScope) / Moonshot / 智谱 / 本地 Ollama 等。

# ===== 大模型（OpenAI 兼容）=====
ISAS_LLM_BASE_URL=https://api.deepseek.com/v1
ISAS_LLM_API_KEY=sk-你的真实Key
ISAS_LLM_MODEL=deepseek-chat
# ISAS_LLM_TIMEOUT=120

# ===== WebFetch 网页抓取服务（如需覆盖 app.json）=====
# ISAS_WEB_FETCH_BASE_URL=http://192.168.0.111:33333
# ISAS_WEB_FETCH_API_KEY=

# ===== JWT 签名密钥（生产建议覆盖为随机串）=====
# ISAS_AUTH_SECRET_KEY=

# ===== 服务端口（如需覆盖 app.json）=====
# ISAS_SERVER_PORT=28080
